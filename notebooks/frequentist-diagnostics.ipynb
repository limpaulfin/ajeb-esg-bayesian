   "source": [
    "# Frequentist Diagnostic Tests\n",
    "\n",
    "**Task:** 14 - Kiểm định chẩn đoán Frequentist  \n",
    "**Date:** 2026-03-10  \n",
    "**Engine:** ",
    "\n",
    "---\n",
    "\n",
    "## Các kiểm định chẩn đoán\n",
    "\n",
    "1. **Modified Wald Test** - Groupwise heteroskedasticity\n",
    "2. **Wooldridge Test** - First-order autocorrelation  \n",
    "3. **Breusch-Pagan LM Test** - Random effects significance\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Import Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import statsmodels.api as sm\n",
    "from statsmodels.regression.linear_model import OLS\n",
    "from linearmodels.panel import PanelOLS, RandomEffects\n",
    "from scipy import stats\n",
    "import json\n",
    "\n",
    "print(\"Libraries loaded successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Load Data và Model Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "df = pd.read_csv('./data/processed/asean-esg-final.csv')\n",
    "\n",
    "# Preprocessing (tương tự Task 13)\n",
    "df_clean = df.copy()\n",
    "df_clean['G_score'] = df_clean.groupby('ISO3 code')['G_score'].transform(lambda x: x.fillna(x.median()))\n",
    "df_clean['G_score'] = df_clean['G_score'].fillna(df_clean['G_score'].median())\n",
    "df_clean['inflation'] = df_clean.groupby('ISO3 code')['inflation'].transform(lambda x: x.fillna(x.median()))\n",
    "df_clean['inflation'] = df_clean['inflation'].fillna(df_clean['inflation'].median())\n",
    "\n",
    "vars_required = ['GDP_growth', 'E_score', 'S_score', 'G_score', 'inflation', 'population_growth']\n",
    "df_panel = df_clean.dropna(subset=vars_required).copy()\n",
    "df_panel = df_panel.set_index(['ISO3 code', 'year'])\n",
    "df_panel = df_panel.sort_index()\n",
    "\n",
    "# Load results từ Task 13\n",
    "with open('./data/processed/frequentist-results.json', 'r') as f:\n",
    "    freq_results = json.load(f)\n",
    "\n",
    "print(f\"Dataset: {df_panel.shape[0]} observations, {df_panel.index.get_level_values(0).nunique()} countries\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Ước lượng lại các mô hình"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Biến\n",
    "y = df_panel['GDP_growth']\n",
    "X_vars = ['E_score', 'S_score', 'G_score', 'inflation', 'population_growth']\n",
    "X = df_panel[X_vars]\n",
    "X_with_const = sm.add_constant(X)\n",
    "\n",
    "# Pooled OLS\n",
    "model_ols = OLS(y, X_with_const)\n",
    "results_ols = model_ols.fit(cov_type='cluster', cov_kwds={'groups': df_panel.index.get_level_values(0)})\n",
    "\n",
    "# Fixed Effects Model\n",
    "model_fem = PanelOLS(y, X, entity_effects=True, time_effects=False)\n",
    "results_fem = model_fem.fit(cov_type='clustered', cluster_entity=True)\n",
    "\n",
    "# Random Effects Model\n",
    "model_rem = RandomEffects(y, X)\n",
    "results_rem = model_rem.fit(cov_type='clustered', cluster_entity=True)\n",
    "\n",
    "print(\"Models estimated successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Modified Wald Test - Groupwise Heteroskedasticity\n",
    "\n",
    "**H0:** Homoskedasticity (phương sai không đổi)  \n",
    "**H1:** Groupwise heteroskedasticity (phương sai khác nhau giữa các quốc gia)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def modified_wald_test(residuals, entities):\n",
    "    \"\"\"\n",
    "    Modified Wald test for groupwise heteroskedasticity\n",
    "    \n",
    "    Reference: Greene (2003), Econometric Analysis\n",
    "    \"\"\"\n",
    "    # Tính residual variance cho mỗi nhóm (quốc gia)\n",
    "    entity_var = residuals.groupby(entities).var()\n",
    "    \n",
    "    # Số nhóm\n",
    "    N = len(entity_var)\n",
    "    \n",
    "    # Mean variance\n",
    "    mean_var = entity_var.mean()\n",
    "    \n",
    "    # Wald statistic: N * sum((sigma_i^2 - sigma^2)^2 / sigma^4)\n",
    "    # Simplified: sum((sigma_i^2 / mean_var - 1)^2)\n",
    "    wald_stat = N * ((entity_var / mean_var - 1) ** 2).sum()\n",
    "    \n",
    "    # Chi-squared với (N-1) degrees of freedom\n",
    "    df = N - 1\n",
    "    p_value = 1 - stats.chi2.cdf(wald_stat, df)\n",
    "    \n",
    "    return wald_stat, df, p_value\n",
    "\n",
    "# Lấy residuals từ FEM\n",
    "entities = df_panel.index.get_level_values(0)\n",
    "residuals_fem = pd.Series(results_fem.resids.flatten(), index=df_panel.index)\n",
    "\n",
    "# Thực hiện Modified Wald test\n",
    "wald_stat, wald_df, wald_pval = modified_wald_test(residuals_fem, entities)\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(\"MODIFIED WALD TEST - GROUPWISE HETEROSKEDASTICITY\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"\\nWald Statistic: {wald_stat:.4f}\")\n",
    "print(f\"Degrees of Freedom: {wald_df}\")\n",
    "print(f\"P-value: {wald_pval:.6f}\")\n",
    "print(f\"\\nKết luận:\")\n",
    "if wald_pval < 0.05:\n",
    "    print(f\"  → Bác bỏ H0 (p = {wald_pval:.4f} < 0.05)\")\n",
    "    print(f\"  → Tồn tại GROUPWISE HETEROSKEDASTICITY\")\n",
    "    print(f\"  → Cần sử dụng ROBUST STANDARD ERRORS\")\n",
    "    hetero_detected = True\n",
    "else:\n",
    "    print(f\"  → Không bác bỏ H0 (p = {wald_pval:.4f} >= 0.05)\")\n",
    "    print(f\"  → Không có bằng chứng heteroskedasticity\")\n",
    "    hetero_detected = False\n",
    "print(\"=\" * 70)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Wooldridge Test - First-Order Autocorrelation\n",
    "\n",
    "**H0:** Không có first-order serial correlation  \n",
    "**H1:** Có first-order serial correlation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def wooldridge_test(residuals, entities, time_periods):\n",
    "    \"\"\"\n",
    "    Wooldridge test for first-order autocorrelation in panel data\n",
    "    \n",
    "    Reference: Wooldridge (2010), Econometric Analysis of Cross Section and Panel Data\n",
    "    \"\"\"\n",
    "    # Tạo DataFrame với residuals\n",
    "    resid_df = pd.DataFrame({'resid': residuals, 'entity': entities, 'time': time_periods})\n",
    "    \n",
    "    # Tính lagged residuals cho mỗi entity\n",
    "    resid_df = resid_df.sort_values(['entity', 'time'])\n",
    "    resid_df['resid_lag'] = resid_df.groupby('entity')['resid'].shift(1)\n",
    "    \n",
    "    # Loại bỏ NaN (first observation của mỗi entity)\n",
    "    resid_clean = resid_df.dropna()\n",
    "    \n",
    "    # Tính correlation\n",
    "    rho = resid_clean['resid'].corr(resid_clean['resid_lag'])\n",
    "    \n",
    "    # T-statistic\n",
    "    n = len(resid_clean)\n",
    "    se_rho = np.sqrt((1 - rho**2) / (n - 2))\n",
    "    t_stat = rho / se_rho\n",
    "    \n",
    "    # P-value (two-tailed)\n",
    "    p_value = 2 * (1 - stats.t.cdf(abs(t_stat), df=n-2))\n",
    "    \n",
    "    return rho, t_stat, p_value, n\n",
    "\n",
    "# Lấy time periods\n",
    "time_periods = df_panel.index.get_level_values(1)\n",
    "\n",
    "# Thực hiện Wooldridge test\n",
    "rho, wooldridge_t, wooldridge_pval, n_obs = wooldridge_test(\n",
    "    residuals_fem.values, entities.values, time_periods.values\n",
    ")\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(\"WOOLDRIDGE TEST - FIRST-ORDER AUTOCORRELATION\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"\\nAutocorrelation coefficient (ρ): {rho:.4f}\")\n",
    "print(f\"T-statistic: {wooldridge_t:.4f}\")\n",
    "print(f\"P-value: {wooldridge_pval:.6f}\")\n",
    "print(f\"Observations used: {n_obs}\")\n",
    "print(f\"\\nKết luận:\")\n",
    "if wooldridge_pval < 0.05:\n",
    "    print(f\"  → Bác bỏ H0 (p = {wooldridge_pval:.4f} < 0.05)\")\n",
    "    print(f\"  → Tồn tại FIRST-ORDER AUTOCORRELATION\")\n",
    "    print(f\"  → Cần sử dụng CLUSTERED STANDARD ERRORS\")\n",
    "    auto_detected = True\n",
    "else:\n",
    "    print(f\"  → Không bác bỏ H0 (p = {wooldridge_pval:.4f} >= 0.05)\")\n",
    "    print(f\"  → Không có bằng chứng autocorrelation\")\n",
    "    auto_detected = False\n",
    "print(\"=\" * 70)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Breusch-Pagan LM Test - Random Effects\n",
    "\n",
    "**H0:** Var(u_i) = 0 (không có random effects)  \n",
    "**H1:** Var(u_i) > 0 (có random effects)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def breusch_pagan_lm_test(residuals_ols, entities, time_periods):\n",
    "    \"\"\"\n",
    "    Breusch-Pagan LM test for random effects\n",
    "    \n",
    "    Reference: Breusch & Pagan (1980), Greene (2003)\n",
    "    \"\"\"\n",
    "    # Số quan sát\n",
    "    n_total = len(residuals_ols)\n",
    "    \n",
    "    # Số entities (N) và time periods (T)\n",
    "    N = entities.nunique()\n",
    "    T_bar = n_total / N  # Average time periods per entity\n",
    "    \n",
    "    # Tính sum of squared residuals\n",
    "    ssr = np.sum(residuals_ols ** 2)\n",
    "    \n",
    "    # Tính sum of squared residuals cho mỗi entity\n",
    "    resid_df = pd.DataFrame({'resid': residuals_ols, 'entity': entities})\n",
    "    entity_ssr = resid_df.groupby('entity')['resid'].apply(lambda x: np.sum(x) ** 2)\n",
    "    sum_entity_ssr = entity_ssr.sum()\n",
    "    \n",
    "    # LM statistic\n",
    "    lm_stat = (n_total / (2 * (T_bar - 1))) * ((sum_entity_ssr / ssr) - 1) ** 2\n",
    "    \n",
    "    # P-value (chi-squared với 1 df)\n",
    "    p_value = 1 - stats.chi2.cdf(lm_stat, df=1)\n",
    "    \n",
    "    return lm_stat, p_value, N, T_bar\n",
    "\n",
    "# Lấy residuals từ Pooled OLS\n",
    "residuals_ols = results_ols.resid\n",
    "\n",
    "# Thực hiện Breusch-Pagan LM test\n",
    "lm_stat, lm_pval, N_entities, T_avg = breusch_pagan_lm_test(\n",
    "    residuals_ols, entities, time_periods\n",
    ")\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(\"BREUSCH-PAGAN LM TEST - RANDOM EFFECTS\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"\\nLM Statistic: {lm_stat:.4f}\")\n",
    "print(f\"P-value: {lm_pval:.6f}\")\n",
    "print(f\"Number of entities (N): {N_entities}\")\n",
    "print(f\"Average time periods (T-bar): {T_avg:.2f}\")\n",
    "print(f\"\\nKết luận:\")\n",
    "if lm_pval < 0.05:\n",
    "    print(f\"  → Bác bỏ H0 (p = {lm_pval:.4f} < 0.05)\")\n",
    "    print(f\"  → RANDOM EFFECTS có ý nghĩa thống kê\")\n",
    "    print(f\"  → REM phù hợp hơn Pooled OLS\")\n",
    "    re_significant = True\n",
    "else:\n",
    "    print(f\"  → Không bác bỏ H0 (p = {lm_pval:.4f} >= 0.05)\")\n",
    "    print(f\"  → Random effects không có ý nghĩa\")\n",
    "    print(f\"  → Pooled OLS có thể phù hợp\")\n",
    "    re_significant = False\n",
    "print(\"=\" * 70)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Tổng hợp Kết quả"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\n\" + \"=\" * 70)\n",
    "print(\"TỔNG HỢP KẾT QUẢ CHẨN ĐOÁN\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "print(\"\\n1. MODIFIED WALD TEST (Heteroskedasticity):\")\n",
    "print(f\"   Wald χ²({wald_df}) = {wald_stat:.4f}, p = {wald_pval:.4f}\")\n",
    "print(f\"   → {'CÓ heteroskedasticity' if hetero_detected else 'Không có heteroskedasticity'}\")\n",
    "\n",
    "print(\"\\n2. WOOLDRIDGE TEST (Autocorrelation):\")\n",
    "print(f\"   ρ = {rho:.4f}, t = {wooldridge_t:.4f}, p = {wooldridge_pval:.4f}\")\n",
    "print(f\"   → {'CÓ autocorrelation' if auto_detected else 'Không có autocorrelation'}\")\n",
    "\n",
    "print(\"\\n3. BREUSCH-PAGAN LM TEST (Random Effects):\")\n",
    "print(f\"   LM = {lm_stat:.4f}, p = {lm_pval:.4f}\")\n",
    "print(f\"   → {'Random effects có ý nghĩa' if re_significant else 'Random effects không ý nghĩa'}\")\n",
    "\n",
    "print(\"\\n\" + \"-\" * 70)\n",
    "print(\"KHUYẾN NGHỊ:\")\n",
    "print(\"-\" * 70)\n",
    "\n",
    "recommendations = []\n",
    "if hetero_detected:\n",
    "    recommendations.append(\"• Sử dụng ROBUST STANDARD ERRORS (đã áp dụng cluster-robust SE)\")\n",
    "if auto_detected:\n",
    "    recommendations.append(\"• Sử dụng CLUSTERED STANDARD ERRORS (đã áp dụng)\")\n",
    "if not hetero_detected and not auto_detected:\n",
    "    recommendations.append(\"• Các giả định OLS được thỏa mãn\")\n",
    "\n",
    "recommendations.append(\"• Hausman test kết luận: REM phù hợp hơn FEM (p = 1.00)\")\n",
    "\n",
    "for rec in recommendations:\n",
    "    print(rec)\n",
    "\n",
    "print(\"=\" * 70)"
   ]
  },
