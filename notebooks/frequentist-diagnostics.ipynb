   "source": [
    "## 8. Lưu Kết quả"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Lưu kết quả chẩn đoán\n",
    "diagnostics_results = {\n",
    "    'modified_wald': {\n",
    "        'statistic': float(wald_stat),\n",
    "        'df': int(wald_df),\n",
    "        'p_value': float(wald_pval),\n",
    "        'heteroskedasticity': bool(hetero_detected)\n",
    "    },\n",
    "    'wooldridge': {\n",
    "        'rho': float(rho),\n",
    "        't_stat': float(wooldridge_t),\n",
    "        'p_value': float(wooldridge_pval),\n",
    "        'autocorrelation': bool(auto_detected)\n",
    "    },\n",
    "    'breusch_pagan_lm': {\n",
    "        'lm_stat': float(lm_stat),\n",
    "        'p_value': float(lm_pval),\n",
    "        'random_effects': bool(re_significant)\n",
    "    },\n",
    "    'summary': {\n",
    "        'hetero_detected': bool(hetero_detected),\n",
    "        'auto_detected': bool(auto_detected),\n",
    "        're_significant': bool(re_significant),\n",
    "        'recommendation': 'Use REM with cluster-robust SE'\n",
    "    }\n",
    "}\n",
    "\n",
    "with open('./data/processed/diagnostics-results.json', 'w') as f:\n",
    "    json.dump(diagnostics_results, f, indent=2, ensure_ascii=False)\n",
    "\n",
    "print(\"✓ Diagnostics results saved to: data/processed/diagnostics-results.json\")"
   ]
  }
